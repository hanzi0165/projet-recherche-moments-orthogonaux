def plot_training_curves(train_losses, val_losses,
                          train_accs,  val_accs, out_path=None):
    """Courbes loss et accuracy pendant l'entraînement."""
    fig, axes = plt.subplots(1, 2, figsize=(12, 4))
    fig.suptitle("FrCMs-DNNs — Courbes d'entraînement", fontsize=12)

    epochs = range(1, len(train_losses) + 1)

    axes[0].plot(epochs, train_losses, label="Train loss")
    axes[0].plot(epochs, val_losses,   label="Val loss")
    axes[0].set_xlabel("Époque")
    axes[0].set_ylabel("Cross-entropy loss")
    axes[0].set_title("Loss")
    axes[0].legend()
    axes[0].grid(True, linestyle="--", alpha=0.6)

    axes[1].plot(epochs, train_accs, label="Train accuracy")
    axes[1].plot(epochs, val_accs,   label="Val accuracy")
    axes[1].set_xlabel("Époque")
    axes[1].set_ylabel("Accuracy")
    axes[1].set_title("Accuracy")
    axes[1].legend()
    axes[1].grid(True, linestyle="--", alpha=0.6)

    plt.tight_layout()
    if out_path:
        fig.savefig(out_path, dpi=200, bbox_inches='tight')
        print(f"  Courbes : {out_path}")
    plt.close(fig)


def plot_confusion_matrix(cm, class_names, out_path=None):
    """Matrice de confusion (comme Figure 10 de l'article)."""
    n = len(class_names)
    fig, ax = plt.subplots(figsize=(max(8, n*0.5), max(6, n*0.45)))

    im = ax.imshow(cm, cmap='Blues')
    ax.set_xticks(range(n))
    ax.set_yticks(range(n))
    ax.set_xticklabels(class_names, rotation=45, ha='right', fontsize=7)
    ax.set_yticklabels(class_names, fontsize=7)
    ax.set_xlabel("Prédit", fontsize=10)
    ax.set_ylabel("Réel",   fontsize=10)
    ax.set_title("Matrice de confusion — FrCMs-DNNs", fontsize=11)

    # Valeurs dans les cellules
    thresh = cm.max() / 2.0
    for i in range(n):
        for j in range(n):
            if cm[i, j] > 0:
                ax.text(j, i, str(cm[i, j]),
                        ha='center', va='center', fontsize=6,
                        color='white' if cm[i, j] > thresh else 'black')

    plt.colorbar(im, ax=ax, fraction=0.03)
    plt.tight_layout()
    if out_path:
        fig.savefig(out_path, dpi=200, bbox_inches='tight')
        print(f"  Matrice de confusion : {out_path}")
    plt.close(fig)


def plot_metrics_bar(metrics, out_path=None):
    """Diagramme en barres Accuracy/Precision/Recall/F1 (comme Figure 12)."""
    labels = ["Accuracy", "Precision", "Recall", "F1-score"]
    values = [metrics["accuracy"], metrics["precision"],
              metrics["recall"],   metrics["f1"]]

    fig, ax = plt.subplots(figsize=(7, 4))
    bars = ax.bar(labels, values, color=['steelblue','darkorange','green','red'],
                  alpha=0.8, width=0.5)
    ax.set_ylim(0, 1.1)
    ax.set_ylabel("Score")
    ax.set_title("FrCMs-DNNs — Métriques de classification", fontsize=11)
    ax.grid(True, axis='y', linestyle="--", alpha=0.5)

    for bar, val in zip(bars, values):
        ax.text(bar.get_x() + bar.get_width()/2, val + 0.02,
                f"{val:.4f}", ha='center', fontsize=10, fontweight='bold')

    plt.tight_layout()
    if out_path:
        fig.savefig(out_path, dpi=200, bbox_inches='tight')
        print(f"  Métriques : {out_path}")
    plt.close(fig)


