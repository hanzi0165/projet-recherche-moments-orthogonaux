# 6. PROGRAMME PRINCIPAL
# ═══════════════════════════════════════════════════════════════════════════════

if __name__ == "__main__":

    # ── Paramètres ───────────────────────────────────────────────────────────
    DATASET_ROOT = Path(r"C:\Users\Flora\Downloads\MPEG7dataset\original")  # ← modifier

    N_MAX   = 10      # ordre des moments — vecteur de dim (N+1)² = 121
    ALPHA_X = 0.9     # meilleur alpha trouvé dans tes expériences
    ALPHA_Y = 0.9

    TEST_SIZE    = 0.60   # 60% test, 40% train — conforme à l'article
    EPOCHS       = 100
    BATCH_SIZE   = 32
    LR           = 1e-3
    DROPOUT      = 0.3
    WEIGHT_DECAY = 1e-4   # régularisation L2

    # ── Sorties ───────────────────────────────────────────────────────────────
    try:
        script_dir = Path(__file__).resolve().parent
    except NameError:
        script_dir = Path.cwd()
    out_dir = script_dir.parent / "outputs"
    out_dir.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime('%Y%m%d_%H%M%S')

    cache_path = out_dir / f"frcmi_features_n{N_MAX}_a{ALPHA_X}.npz"

    # ── 1. Extraction des features ────────────────────────────────────────────
    print("=" * 60)
    print("Étape 1 : Extraction des features FrCMI")
    print("=" * 60)
    t0 = time.time()
    X, y_labels = extract_all_features(
        DATASET_ROOT, N_MAX, ALPHA_X, ALPHA_Y, cache_path=cache_path
    )
    print(f"  Temps extraction : {time.time()-t0:.1f}s")
    print()

    # ── 2. Encodage des labels ────────────────────────────────────────────────
    le = LabelEncoder()
    y  = le.fit_transform(y_labels)
    class_names = list(le.classes_)
    n_classes   = len(class_names)
    input_dim   = X.shape[1]

    print(f"  Dimension vecteur FrCMI : {input_dim}  (= (N+1)² = {(N_MAX+1)**2})")
    print(f"  Nombre de classes       : {n_classes}")
    print(f"  Exemples par classe     : {len(X) // n_classes} (environ)")
    print()

    # ── 3. Split train/test — conforme à l'article (40%/60%) ─────────────────
    label_counts = Counter(y)
    rare_classes = {cls for cls, cnt in label_counts.items() if cnt < 2}

    if rare_classes:
        rare_names = [le.classes_[i] for i in rare_classes]
        print(f"  [INFO] Classes ignorées : {rare_names}")
        mask = np.array([yi not in rare_classes for yi in y])
        X = X[mask]
        y = y[mask]
        print(f"  Après filtrage : {len(X)} images, {len(np.unique(y))} classes")
        print()

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=TEST_SIZE, random_state=42, stratify=y
    )
    print(f"  Train : {len(X_train)} images")
    print(f"  Test  : {len(X_test)} images")
    print()
    

    # Normalisation (z-score)
    mean = X_train.mean(axis=0)
    std  = X_train.std(axis=0) + 1e-8
    X_train = (X_train - mean) / std
    X_test  = (X_test  - mean) / std

    # DataLoaders
    train_ds = TensorDataset(torch.tensor(X_train), torch.tensor(y_train, dtype=torch.long))
    test_ds  = TensorDataset(torch.tensor(X_test),  torch.tensor(y_test,  dtype=torch.long))
    train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True)
    test_loader  = DataLoader(test_ds,  batch_size=BATCH_SIZE, shuffle=False)

    # ── 4. Création du modèle ─────────────────────────────────────────────────
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"  Device : {device}")

    model     = FrCMsDNN(input_dim, n_classes, DROPOUT).to(device)
    criterion = nn.CrossEntropyLoss()
    optimizer = optim.Adam(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)
    scheduler = optim.lr_scheduler.StepLR(optimizer, step_size=30, gamma=0.5)

    print(f"\n  Paramètres du modèle : {sum(p.numel() for p in model.parameters()):,}")
    print()

    # ── 5. Entraînement ───────────────────────────────────────────────────────
    print("=" * 60)
    print("Étape 2 : Entraînement FrCMs-DNNs")
    print("=" * 60)

    train_losses, val_losses = [], []
    train_accs,   val_accs   = [], []
    best_val_acc  = 0.0
    best_state    = None

    for epoch in range(1, EPOCHS + 1):
        tr_loss, tr_acc = train_epoch(model, train_loader, optimizer, criterion, device)
        va_loss, va_acc, _, _ = evaluate(model, test_loader, criterion, device)
        scheduler.step()

        train_losses.append(tr_loss);  val_losses.append(va_loss)
        train_accs.append(tr_acc);     val_accs.append(va_acc)

        if va_acc > best_val_acc:
            best_val_acc = va_acc
            best_state   = {k: v.clone() for k, v in model.state_dict().items()}

        if epoch % 10 == 0 or epoch == 1:
            print(f"  Époque {epoch:3d}/{EPOCHS}  "
                  f"loss={tr_loss:.4f}  acc_train={tr_acc:.4f}  "
                  f"acc_val={va_acc:.4f}  (best={best_val_acc:.4f})")

    # Restaurer le meilleur modèle
    model.load_state_dict(best_state)
    print(f"\n  Meilleure accuracy validation : {best_val_acc:.4f}")

    # ── 6. Évaluation finale ──────────────────────────────────────────────────
    print()
    print("=" * 60)
    print("Étape 3 : Évaluation finale")
    print("=" * 60)

    _, _, y_true, y_pred = evaluate(model, test_loader, criterion, device)
    metrics = compute_metrics(y_true, y_pred, class_names)

    print(f"  Accuracy  : {metrics['accuracy']:.4f}")
    print(f"  Precision : {metrics['precision']:.4f}")
    print(f"  Recall    : {metrics['recall']:.4f}")
    print(f"  F1-score  : {metrics['f1']:.4f}")

    # ── 7. Sauvegarde des figures ─────────────────────────────────────────────
    plot_training_curves(train_losses, val_losses, train_accs, val_accs,
                          out_path=out_dir / f"dnn_curves_{ts}.png")

    plot_confusion_matrix(metrics["confusion_matrix"], class_names,
                           out_path=out_dir / f"dnn_confusion_{ts}.png")

    plot_metrics_bar(metrics,
                     out_path=out_dir / f"dnn_metrics_{ts}.png")

    # ── 8. Sauvegarde CSV des résultats ───────────────────────────────────────
    csv_path = out_dir / f"dnn_results_{ts}.csv"
    with csv_path.open("w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=["metric", "value"])
        w.writeheader()
        for k, v in metrics.items():
            if k != "confusion_matrix":
                w.writerow({"metric": k, "value": f"{v:.6f}"})
    print(f"\n  CSV résultats : {csv_path}")
    print(f"  Fichiers dans : {out_dir}")

    # ── 9. Tableau récapitulatif ──────────────────────────────────────────────
    print()
    print("=" * 40)
    print("  Résumé final FrCMs-DNNs")
    print("-" * 40)
    print(f"  N_max    = {N_MAX}  (dim={input_dim})")
    print(f"  Alpha    = ({ALPHA_X}, {ALPHA_Y})")
    print(f"  Classes  = {n_classes}")
    print(f"  Train/Test = {100-int(TEST_SIZE*100)}% / {int(TEST_SIZE*100)}%")
    print(f"  Epochs   = {EPOCHS}")
    print("-" * 40)
    print(f"  Accuracy  = {metrics['accuracy']:.4f}")
    print(f"  Precision = {metrics['precision']:.4f}")
    print(f"  Recall    = {metrics['recall']:.4f}")
    print(f"  F1-score  = {metrics['f1']:.4f}")
    print("=" * 40)