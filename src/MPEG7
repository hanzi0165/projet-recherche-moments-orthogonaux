from PIL import Image
import numpy as np
import matplotlib.pyplot as plt
import os
from datetime import datetime

from moments_2d import chebyshev_moments_2d
from reconstruction import reconstruct_2d
from metrics import mse, psnr

path = r"C:\Users\Flora\Downloads\MPEG7dataset\original\teddy-03.gif"

# 1. Lire l'image originale
img_pil = Image.open(path).convert("L")
arr = np.array(img_pil, dtype=np.float64)

# Ajout : vérifier la taille de l'image
print("PIL size (width, height):", img_pil.size)
print("NumPy shape (height, width):", arr.shape)

# Préparer le répertoire de sortie et le timestamp
out_dir = os.path.abspath(os.path.join(os.path.dirname(__file__), '..', 'outputs'))
os.makedirs(out_dir, exist_ok=True)
ts = datetime.now().strftime('%Y%m%d_%H%M%S')

# 2. Binarisation
img = (arr > 127).astype(np.float64)

# 3. Choisir plusieurs valeurs de N
n_values = [5, 10, 20, 30, 40, 50, 60]

# 4. Afficher les métriques pour chaque N
print("Image shape:", img.shape)
print("Unique values:", np.unique(img))
print()

results = []
mse_values = []
psnr_values = []

for n_max in n_values:
    M, Tx, Ty = chebyshev_moments_2d(img, n_max)
    rec = reconstruct_2d(M, Tx, Ty)

    m = mse(img, rec)
    p = psnr(img, rec)

    results.append((n_max, rec, m, p))
    mse_values.append(m)
    psnr_values.append(p)

    print(f"N = {n_max}")
    print("  Moment shape:", M.shape)
    print("  MSE:", m)
    print("  PSNR:", p)
    print()

# 5. Image originale + images reconstruites
num_plots = 1 + len(n_values)
fig = plt.figure(figsize=(4 * num_plots, 4))

plt.subplot(1, num_plots, 1)
plt.imshow(img, cmap="gray")
plt.title("Original")
plt.axis("off")

for idx, (n_max, rec, m, p) in enumerate(results, start=2):
    plt.subplot(1, num_plots, idx)
    plt.imshow(rec, cmap="gray")
    plt.title(f"N={n_max}\nMSE={m:.2e}\nPSNR={p:.2f}")
    plt.axis("off")

plt.tight_layout()
fig_path = os.path.join(out_dir, f'MPEG7_recon_{ts}.png')
fig.savefig(fig_path, dpi=300, bbox_inches='tight')
plt.close(fig)
print('Saved reconstruction figure to', fig_path)

# 6. Courbe MSE
fig = plt.figure(figsize=(6, 4))
plt.semilogy(n_values, mse_values, marker='o')
plt.xlabel("N")
plt.ylabel("MSE")
plt.title("MSE vs Reconstruction Order")
plt.grid(True, which="both")

# Afficher les valeurs MSE exactes sur l'axe Y
plt.yticks(mse_values, [f"{v:.4f}" for v in mse_values])

# Laisser de la marge en haut et en bas pour éviter la troncature
plt.ylim([min(mse_values) * 0.8, max(mse_values) * 1.3])

plt.tight_layout(pad=1.5)
mse_path = os.path.join(out_dir, f'MPEG7_mse_{ts}.png')
fig.savefig(mse_path, dpi=300, bbox_inches='tight')
plt.close(fig)
print('Saved MSE figure to', mse_path)

# 7. Courbe PSNR
fig = plt.figure(figsize=(6, 4))
plt.plot(n_values, psnr_values, marker='o')
plt.xlabel("N")
plt.ylabel("PSNR")
plt.title("PSNR vs Reconstruction Order")
plt.grid(True)
plt.tight_layout()
psnr_path = os.path.join(out_dir, f'MPEG7_psnr_{ts}.png')
fig.savefig(psnr_path, dpi=300, bbox_inches='tight')
plt.close(fig)
print('Saved PSNR figure to', psnr_path)