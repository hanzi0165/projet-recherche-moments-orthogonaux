# 9. PROGRAMME PRINCIPAL
# ═══════════════════════════════════════════════════════════════════════════════

if __name__ == "__main__":

    # ── Paramètres ───────────────────────────────────────────────────────────
    IM_PATH     = r"C:\Users\Flora\Downloads\cupsIm\cupsIm\b1.im.gz"
    ALPHA       = 1.0      # paramètre fractionnaire (optimal sur MPEG-7 2D)
    N_VALUES    = [3, 5, 8, 10, 13,16]   # ordres à tester
    RENDER_SIZE = 32       # résolution pour le rendu voxel (32 = rapide)
    # Note : frac_basis() est lent pour n_max élevé sur 128³
    # Commencer par N_VALUES=[3,5,8] pour valider

    # ── Sorties ───────────────────────────────────────────────────────────────
    try:
        script_dir = Path(__file__).resolve().parent
    except NameError:
        script_dir = Path.cwd()
    out_dir = script_dir.parent / "outputs"
    out_dir.mkdir(parents=True, exist_ok=True)
    ts   = datetime.now().strftime('%Y%m%d_%H%M%S')
    stem = Path(IM_PATH).stem

    # ── Chargement ───────────────────────────────────────────────────────────
    print(f"Chargement : {Path(IM_PATH).name}")
    # Debug prints to help diagnose FileNotFoundError
    print(f"DEBUG IM_PATH repr: {IM_PATH!r}")
    print(f"DEBUG IM_PATH exists: {Path(IM_PATH).exists()}  CWD: {Path.cwd()}")
    print(f"DEBUG N_VALUES: {N_VALUES}")
    vol = load_im_gz(IM_PATH)
    print(f"Shape    : {vol.shape}")
    print(f"Voxels actifs : {int(vol.sum())} ({100*vol.mean():.1f}%)")
    print()

    # ── Boucle sur N ─────────────────────────────────────────────────────────
    mse_values  = []
    psnr_values = []
    last_rec    = None

    for n_max in N_VALUES:
        print(f"N={n_max}  α={ALPHA}  →  (N+1)³ = {(n_max+1)**3} moments ...")
        C, Tx, Ty, Tz = frcm_3d(vol, n_max,
                                   alpha_x=ALPHA,
                                   alpha_y=ALPHA,
                                   alpha_z=ALPHA)
        rec = reconstruct_frcm_3d(C, Tx, Ty, Tz)

        m = mse_3d(vol, rec)
        p = psnr_3d(vol, rec)
        mse_values.append(m)
        psnr_values.append(p)
        last_rec = rec

        print(f"  MSE  = {m:.6f}")
        print(f"  PSNR = {p:.2f} dB")
        print()

    # ── Binarisation de la reconstruction ────────────────────────────────────
    threshold = last_rec.mean() + 2 * last_rec.std()
    rec_bin   = (last_rec > threshold).astype(np.float64)
    dice_val, TP, FP, FN = dice(vol, rec_bin)
    print(f"Binarisation seuil = {threshold:.4f}")
    print(f"DICE = {dice_val:.4f}  TP={TP}  FP={FP}  FN={FN}")
    print()

    # ── Réduction pour rendu voxel ────────────────────────────────────────────
    print(f"Réduction à {RENDER_SIZE}³ pour le rendu ...")
    orig_s = downsample(vol,     RENDER_SIZE)
    rec_s  = downsample(rec_bin, RENDER_SIZE)

    # ── Figure 3 panneaux ─────────────────────────────────────────────────────
    fig_path = out_dir / f"frcm3d_{stem}_N{N_VALUES[-1]}_a{ALPHA}_{ts}.png"
    plot_3d_voxel(orig_s, rec_s,
                  n_max=N_VALUES[-1], alpha=ALPHA,
                  dice_val=dice_val,
                  mse_val=mse_values[-1],
                  psnr_val=psnr_values[-1],
                  out_path=fig_path)

    # ── Courbes MSE/PSNR ──────────────────────────────────────────────────────
    curves_path = out_dir / f"frcm3d_curves_{stem}_a{ALPHA}_{ts}.png"
    plot_curves(N_VALUES, mse_values, psnr_values,
                alpha=ALPHA, out_path=curves_path)

    # ── Tableau ───────────────────────────────────────────────────────────────
    print("=" * 50)
    print(f"{'N':>4}  {'(N+1)³':>8}  {'MSE':>12}  {'PSNR':>8}")
    print("-" * 50)
    for n, m, p in zip(N_VALUES, mse_values, psnr_values):
        print(f"{n:>4}  {(n+1)**3:>8}  {m:>12.6f}  {p:>8.2f} dB")
    print("=" * 50)